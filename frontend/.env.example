# Configuration for Nexus Hestia Image Sorter Frontend
# Since this frontend will be hosted on Bluehost (demo.nexushestia.com),
# you must point it to your Python backend running on Railway.

# Replace the URL below with your actual Railway public domain:
# Example: https://nhtimagesort-production.up.railway.app
VITE_API_URL=https://[YOUR_RAILWAY_APP_URL]
